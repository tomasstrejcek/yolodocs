{
  "name": "yolodocs",
  "version": "0.1.26",
  "description": "Generate beautiful, searchable, static documentation sites from GraphQL schemas",
  "type": "module",
  "bin": {
    "yolodocs": "./dist/bin/yolodocs.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:e2e": "npx playwright test",
    "lint": "oxlint src/ bin/",
    "format": "oxfmt src/ bin/",
    "format:check": "oxfmt --check src/ bin/",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "graphql",
    "documentation",
    "static-site",
    "api-docs"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "graphql": "^16.9.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
